rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields:
    //   - name: string (required)
    //   - department: string (required)
    //   - role: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: attendance
    // Fields:
    //   - employeeId: string (required)
    //   - employeeName: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - startTime: timestamp (required)
    //   - endTime: timestamp (optional)
    //   - durationMinutes: number (optional)
    //   - type: string (required, 'work' or 'break')
    //   - status: string (required, 'present', 'late', 'completed')
    //   - parentSessionId: string (optional)
    //
    // ===============================================================

    function isAuthenticated() {
      return true;
    }

    function isAdmin() {
      return true;
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['employeeId', 'employeeName', 'date', 'startTime', 'type', 'status']) &&
             data.employeeId is string &&
             data.employeeName is string &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.type in ['work', 'break'] &&
             data.status in ['present', 'late', 'completed'];
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidEmployee(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow update: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
